# Copy to .env and fill in. Never commit your real .env.

# From @BotFather (message /newbot, it hands you a token). Required.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Your own chat id — the bot serves ONLY this chat and ignores everyone else.
# Get it: message your bot, then open
#   https://api.telegram.org/bot<token>/getUpdates  and read message.chat.id
ALLOWED_CHAT_ID=000000000

# How to transcribe the voice note. Gets the audio path substituted as {audio}
# and a temp dir as {outdir}; must print the transcript to stdout.
# Default uses openai-whisper (`pip install -U openai-whisper`, needs ffmpeg).
# TRANSCRIBE_CMD=whisper "{audio}" --model small --output_format txt --output_dir {outdir} && cat {outdir}/*.txt

# What to DO with the transcript. Gets the transcript on stdin, prints the reply
# to stdout. This is where your agent goes. Examples:
#   EXEC_CMD=claude -p            # pipe the transcript to Claude Code, reply with its output
#   EXEC_CMD=cat                  # (default) echo it back — proves the loop before wiring an agent
# EXEC_CMD=claude -p
